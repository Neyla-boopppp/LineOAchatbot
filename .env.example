# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# Google Gemini API — used by LINE OA chatbot — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (สำรอง) Groq API — provider เดิมของบอท ปัจจุบันไม่ได้ใช้แล้ว
# เก็บไว้เผื่อสลับกลับ: ต้องกู้ lib/ai/groq.ts + groq-sdk จาก git history ด้วย (branch feature/gemini-migration)
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API — used by Jeeb Team agents (Job, Jarb, Jetaime, Jub, Jib, Jan)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Sheet CSV URL — ระบุ gid=0 (Job_Vacancies tab) + single=true เพื่อดึงเฉพาะ tab นั้น
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vRVvSIeJIXKGzn5gmsdmhfboId7Wd3K9aX-RLgEK24PmRPJtnzB0GYlWdFkOPd0CVhZHkccxjy1IAS1/pub?gid=0&single=true&output=csv


# Admin API secret — ป้องกัน debug endpoint /api/admin/jobs (ถ้าไม่ตั้ง endpoint จะถูกปิด = 503)
# สร้าง token สุ่มยาวๆ เช่น: openssl rand -hex 32
# วิธีเรียก: curl -H "x-admin-secret: <token>" "https://<host>/api/admin/jobs?q=barista"
ADMIN_API_SECRET=change_me_to_a_long_random_string

# LINE Group Chat ID ของทีม HR
# วิธีหา: เพิ่มบอทเข้ากลุ่ม → ส่งข้อความใดก็ได้ → ดู webhook log หา source.groupId
HR_LINE_GROUP_ID=C_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel KV — session storage (ใส่หลัง connect KV ใน Vercel dashboard)
# วิธีได้: Vercel Project → Storage → Create KV Database → env vars ถูก inject อัตโนมัติ
# ถ้าไม่ใส่ → fallback เป็น in-memory (state หายทุก cold start)
KV_REST_API_URL=https://xxxxxxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
